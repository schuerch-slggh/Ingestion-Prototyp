# OpenAI / Azure OpenAI
OPENAI_API_KEY=sk-...

# Embedding-Modell (wird in config.py als Default referenziert)
# EMBEDDING_MODEL=text-embedding-3-large

# LLM-Modell (wird in config.py als Default referenziert)
# LLM_MODEL=gpt-4.1

# LLM-Temperatur für deterministische Generierung
# LLM_TEMPERATURE=0.0

# Pipeline-Variante (v0, v1, v2, v3)
# VARIANT=v0
